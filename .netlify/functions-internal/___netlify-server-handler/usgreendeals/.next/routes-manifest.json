      "regex": "^/thank\\-you/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/thank\\-you/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/[slug]",
